# Stripe Configuration
# Production uses only these two Stripe env vars.
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_signing_secret_here

# Netlify Site URL
SITE_URL=https://your-site.netlify.app

# Firebase Admin SDK (for serverless functions)
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYour private key here\n-----END PRIVATE KEY-----\n"
# Alternative: Full service account JSON
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"..."}

# SendGrid Email (for notifications)
SENDGRID_API_KEY=SG.your_sendgrid_api_key_here
FROM_EMAIL=noreply@winnpro-shows.app
APP_NAME=WinnPro Shows
APP_URL=https://your-site.netlify.app
# Optional but recommended: shared secret for trusted server-to-server function calls
# If omitted, internal calls fall back to STRIPE_WEBHOOK_SECRET
INTERNAL_FUNCTIONS_KEY=your_internal_functions_secret_here

# Admin Emails (comma-separated)
ADMIN_EMAILS=admin@example.com,manager@example.com

# Optional: Override defaults
# BOOTH_PRICE=950
# POWER_FEE=75
# TABLE_FEE=25
# CHAIR_FEE=10
